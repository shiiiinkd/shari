# apps/backend/.dev.vars （ローカル開発用）のテンプレート。
# 実ファイル .dev.vars は .gitignore 済み。値を入れて .dev.vars にコピーすること。
# 本番（Cloudflare Workers）には `wrangler secret put <KEY>` で投入する。
# 新規シークレットを足すときの完全な手順は /setup-secret skill を参照。

# --- Anthropic Claude API ---
ANTHROPIC_API_KEY=

# --- LLM provider 切替 ---
# 未指定 / "claude" → Claude API を使う (MVP デフォルト)
# "gemini" → Phase 2 で追加予定。現状は throw する
# LLM_PROVIDER=claude

# --- 字幕取得 (Supadata) ---
# 必須。https://supadata.ai でサインアップ → API key を取得
# 無料枠: 100 req / 月程度
SUPADATA_API_KEY=

# --- Transcript provider 切替 ---
# 未指定 / "supadata" → Supadata を使う (MVP デフォルト)
# TRANSCRIPT_PROVIDER=supadata

# --- Supabase ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
# サーバ専用。mobile / クライアントに絶対渡さない。
SUPABASE_SERVICE_ROLE_KEY=

# --- 外部API（任意） ---
# Qiita: 未設定でも動くがレート制限が厳しい
QIITA_TOKEN=

# --- CORS ---
# カンマ区切りで複数指定可。dev は `*`、本番は https://shari.app 等に絞る。
ALLOWED_ORIGIN=*
