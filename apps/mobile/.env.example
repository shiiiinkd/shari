# apps/mobile/.env （ローカル開発用）のテンプレート。
# 実ファイル .env は .gitignore 済み。値を入れて .env にコピーすること。
# EXPO_PUBLIC_* プレフィックスはクライアントバンドルに含まれるので、
# 公開しても良い値（backend URL や Supabase anon key 等）に限る。
# サーバ専用シークレット（service_role など）は絶対に書かない。

# tRPC backend URL。開発機別の切替は /expo-dev skill を参照。
#   iOS Simulator:    http://localhost:8787/trpc
#   Android Emulator: http://10.0.2.2:8787/trpc
#   実機:             http://<PC の LAN IP>:8787/trpc
EXPO_PUBLIC_TRPC_URL=http://localhost:8787/trpc

# Supabase（mobile が直接叩く場合に使用。MVP の早い段階で必要になる）
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
